{
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "src/lib/db/schema.ts,src/lib/games-config.ts,src/emails/GameLaunchEmail.ts",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
